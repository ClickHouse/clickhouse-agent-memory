# ============================================
# Enterprise Agent Memory -- Configuration
# ============================================

# -- Provider API Keys (set the ones you use) --
GOOGLE_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -- Self-hosted endpoints (optional) --
OLLAMA_BASE_URL=http://ollama:11434
VLLM_BASE_URL=http://vllm:8000

# -- Active provider for cookbook CLI runner --
# Options: gemini, openai, anthropic, ollama, vllm
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash-001
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
EMBED_DIM=768

# -- ClickHouse --
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_DB=enterprise_memory

# -- PuppyGraph --
PUPPYGRAPH_HOST=puppygraph
PUPPYGRAPH_PORT=8182
