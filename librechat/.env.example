# ============================================================================
# LibreChat environment for the Enterprise Agent Memory demo.
# Copy to `.env` and fill in at least GOOGLE_KEY for the default presets.
# ============================================================================

# ---- LibreChat core -----
# Secrets -- generate with `openssl rand -hex 32` each, or leave for a dev demo.
JWT_SECRET=replace-me-dev-secret-jwt
JWT_REFRESH_SECRET=replace-me-dev-secret-refresh
CREDS_KEY=f34be427ebb29de8d88c107a71546019685ed8b241d8f2ed00c3df97ad2566f0
CREDS_IV=e2341419ec3dd3d19b13a1a87fafcbfb

# Login / registration
ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=true

# Meilisearch
MEILI_MASTER_KEY=local-dev-key

# ---- LLM providers -----
# Gemini (default for all preset personas)
GOOGLE_KEY=

# OpenAI (optional)
OPENAI_API_KEY=

# Anthropic (optional)
ANTHROPIC_API_KEY=

# Ollama (optional, defaults to the host machine)
# On macOS / Windows Docker Desktop this resolves to the host's Ollama.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ---- Memory MCP server -----
# These mirror the cookbook .env and let the MCP server reach ClickHouse.
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_DB=enterprise_memory

# Embedding provider for vector search (leave blank for deterministic fallback).
# Supported: gemini, openai, ollama, vllm
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
EMBED_DIM=768
